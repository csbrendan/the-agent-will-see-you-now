# Copy this file to .env and fill in real values. NEVER commit .env.
ANTHROPIC_API_KEY=your_api_key_here

# Per-agent model configuration (see ProjectPlan.md / AGENTS.md).
# Faster config for the Talker; more capable config for Planner/Verifier when latency permits.
MEDBRIDGE_EXTRACTOR_MODEL=claude-opus-4-8
MEDBRIDGE_PLANNER_MODEL=claude-opus-4-8
MEDBRIDGE_TALKER_MODEL=claude-opus-4-8
MEDBRIDGE_VERIFIER_MODEL=claude-opus-4-8
MEDBRIDGE_EVALUATOR_MODEL=claude-opus-4-8

# Local audio model for speech items (LOC-Questions, Language, Dysarthria).
# MIT-licensed, runs on Apple Silicon / whisper.cpp — no GPU required.
MEDBRIDGE_WHISPER_MODEL=base

MEDBRIDGE_DEMO_MODE=true
MEDBRIDGE_LOG_LEVEL=INFO
MEDBRIDGE_FRAME_INTERVAL_SECONDS=1.0
MEDBRIDGE_MAX_VIDEO_SECONDS=120
