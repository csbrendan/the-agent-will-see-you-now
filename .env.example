# Copy to .env and fill in real values. Never commit .env.
ANTHROPIC_API_KEY=your_api_key_here

MEDBRIDGE_EXTRACTOR_MODEL=claude-opus-4-8
MEDBRIDGE_PLANNER_MODEL=claude-opus-4-8
MEDBRIDGE_TALKER_MODEL=claude-haiku-4-5-20251001
MEDBRIDGE_VERIFIER_MODEL=claude-sonnet-5
MEDBRIDGE_EVALUATOR_MODEL=claude-sonnet-5

MEDBRIDGE_DEMO_MODE=true
MEDBRIDGE_LOG_LEVEL=INFO
MEDBRIDGE_FRAME_INTERVAL_SECONDS=1.0
MEDBRIDGE_MAX_VIDEO_SECONDS=120
